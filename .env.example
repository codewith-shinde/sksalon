# SK Unique Studio — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Only variables prefixed with VITE_ are exposed to the frontend bundle,
# so never put secrets (API keys, tokens) in a VITE_ variable.
#
# On Cloudflare Pages, set these under:
#   Project → Settings → Environment variables (Production & Preview)

# Public business contact (safe to expose)
VITE_WHATSAPP_NUMBER=447404797054
VITE_PHONE_NUMBER=+447404797054
VITE_CONTACT_EMAIL=skuniquestudio@yahoo.com

# Optional: Google Maps embed query — use the exact address (not the name,
# which resolves to the wrong pin)
VITE_MAPS_QUERY=10+Colliergate,+YO1+8BP
